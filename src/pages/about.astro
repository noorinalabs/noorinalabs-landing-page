---
/**
 * About page — renders src/content/pages/about.mdx through PageLayout.
 *
 * Loads the "about" entry from the pages content collection and passes
 * frontmatter fields to PageLayout for meta tags and heading.
 */
import { getEntry, render } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";

const entry = await getEntry("pages", "about");
if (!entry) throw new Error("Missing content entry: pages/about");
if (entry.data.draft) return Astro.redirect("/404");

const { Content } = await render(entry);
const { title, description, ogImage } = entry.data;
---

<PageLayout
  title={title}
  description={description}
  ogImage={ogImage?.src}
  ogImageAlt={ogImage?.alt}
>
  <article class="about-page">
    <h1>{title}</h1>
    <Content />
  </article>
</PageLayout>

<style>
  /*
   * About-page typography (#69)
   * about.astro previously had no <style> block, so the MDX body rendered as
   * unstyled prose. These rules give it a readable measure and brand-consistent
   * headings. The page wrapper is scoped; the MDX body is styled via the global
   * block below (rendered outside this component's scope).
   */
  .about-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 7rem 1.5rem 5rem;
  }

  .about-page > h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
    margin-bottom: 1.5rem;
  }
</style>

<style is:global>
  .about-page h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin: 2.5rem 0 1rem;
  }

  .about-page h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin: 2rem 0 0.75rem;
  }

  .about-page p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-muted-foreground);
    margin-bottom: 1.25rem;
  }

  .about-page ul {
    margin: 0 0 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .about-page li {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-muted-foreground);
  }

  .about-page a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .about-page strong {
    color: var(--color-foreground);
    font-weight: 700;
  }

  .about-page em {
    color: var(--color-foreground);
  }
</style>
