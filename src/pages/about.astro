---
/**
 * About page — renders src/content/pages/about.mdx through PageLayout.
 *
 * Loads the "about" entry from the pages content collection and passes
 * frontmatter fields to PageLayout for meta tags and heading.
 */
import { getEntry, render } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";

const entry = await getEntry("pages", "about");
if (!entry) throw new Error("Missing content entry: pages/about");

const { Content } = await render(entry);
const { title, description, ogImage } = entry.data;
---

<PageLayout
  title={title}
  description={description}
  ogImage={ogImage?.src}
  ogImageAlt={ogImage?.alt}
>
  <article class="about-page">
    <h1>{title}</h1>
    <Content />
  </article>
</PageLayout>
