---
import PageLayout from "../layouts/PageLayout.astro";
import SEO from "../components/SEO.astro";
---

<PageLayout
  title="Home"
  description="NoorinALabs builds open tools for Islamic scholarly research — starting with the Isnad Graph, a computational hadith analysis platform."
>
  <SEO slot="head" />

  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="hero-content">
      <h1 id="hero-heading" class="hero-title">
        Open Tools for<br />Islamic Scholarly Research
      </h1>
      <p class="hero-subtitle">
        NoorinALabs brings computational analysis to the Islamic scholarly
        tradition — making centuries of knowledge navigable, searchable, and
        accessible to researchers, students, and curious minds.
      </p>
      <div class="hero-actions">
        <a href="https://isnad-graph.noorinalabs.com" class="btn-primary">
          Explore the Isnad Graph
        </a>
        <a href="/about" class="btn-secondary"> Learn About Us </a>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section" aria-labelledby="mission-heading">
    <div class="section-container">
      <h2 id="mission-heading" class="section-title">What We Do</h2>
      <div class="mission-grid">
        <div class="mission-text">
          <p>
            Islamic scholarship has produced one of the most rigorous systems of
            knowledge verification in human history. For over a millennium,
            scholars have catalogued chains of narration, evaluated the
            reliability of narrators, and traced the pathways through which
            knowledge was transmitted.
          </p>
          <p>
            NoorinALabs builds open-source tools that bring modern computational
            methods to this tradition — not to replace scholarly judgment, but
            to make the underlying data more accessible and the connections more
            visible.
          </p>
        </div>
        <div class="mission-highlight">
          <blockquote>
            <p>
              "Verily, this knowledge is religion, so be careful from whom you
              take your religion."
            </p>
            <cite>— Imam Muhammad ibn Sirin</cite>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Project -->
  <section
    id="projects"
    class="section section-alt"
    aria-labelledby="project-heading"
  >
    <div class="section-container">
      <h2 id="project-heading" class="section-title">Featured Project</h2>
      <div class="project-card">
        <div class="project-card-icon" aria-hidden="true">
          <svg
            viewBox="0 0 64 64"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            width="64"
            height="64"
          >
            <circle cx="32" cy="12" r="6" stroke="currentColor" stroke-width="2"
            ></circle>
            <circle cx="12" cy="44" r="6" stroke="currentColor" stroke-width="2"
            ></circle>
            <circle cx="52" cy="44" r="6" stroke="currentColor" stroke-width="2"
            ></circle>
            <circle cx="32" cy="52" r="4" stroke="currentColor" stroke-width="2"
            ></circle>
            <line
              x1="32"
              y1="18"
              x2="14"
              y2="39"
              stroke="currentColor"
              stroke-width="2"></line>
            <line
              x1="32"
              y1="18"
              x2="50"
              y2="39"
              stroke="currentColor"
              stroke-width="2"></line>
            <line
              x1="16"
              y1="48"
              x2="28"
              y2="52"
              stroke="currentColor"
              stroke-width="2"></line>
            <line
              x1="48"
              y1="48"
              x2="36"
              y2="52"
              stroke="currentColor"
              stroke-width="2"></line>
          </svg>
        </div>
        <div class="project-card-content">
          <h3 class="project-card-title">The Isnad Graph</h3>
          <p class="project-card-description">
            A computational hadith analysis platform that maps chains of
            narration (<span lang="ar">أسانيد</span>) as an interactive,
            searchable graph. Search across collections, explore narrator
            networks, and trace transmission pathways through a modern research
            interface.
          </p>
          <ul class="project-card-features" role="list">
            <li>Cross-collection search across major hadith sources</li>
            <li>Interactive graph visualization of narrator networks</li>
            <li>Biographical profiles with teacher-student relationships</li>
            <li>
              Cross-tradition comparison across Sunni and Shia collections
            </li>
            <li>Every data point traced to published scholarly works</li>
          </ul>
          <a href="https://isnad-graph.noorinalabs.com" class="btn-primary">
            Explore the Isnad Graph
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why NoorinALabs -->
  <section class="section" aria-labelledby="why-heading">
    <div class="section-container">
      <h2 id="why-heading" class="section-title">Why NoorinALabs</h2>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
            >
              <path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
                fill="currentColor"></path>
            </svg>
          </div>
          <h3 class="value-title">Open Source</h3>
          <p class="value-description">
            All our tools are open source. Transparency is essential when
            working with knowledge that carries deep scholarly and spiritual
            significance.
          </p>
        </div>

        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
            >
              <path
                d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z"
                fill="currentColor"></path>
            </svg>
          </div>
          <h3 class="value-title">Scholarly Rigor</h3>
          <p class="value-description">
            Every data point traces back to published scholarly works. We do not
            replace scholarly judgment — we make the evidence more accessible.
          </p>
        </div>

        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
            >
              <path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                fill="currentColor"></path>
            </svg>
          </div>
          <h3 class="value-title">Accessible to All</h3>
          <p class="value-description">
            From seasoned researchers to curious first-time visitors, our tools
            are designed to welcome everyone into the scholarly tradition.
          </p>
        </div>

        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
            >
              <path
                d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                fill="currentColor"></path>
            </svg>
          </div>
          <h3 class="value-title">Community Driven</h3>
          <p class="value-description">
            Built in collaboration with scholars, students, and developers who
            share a commitment to preserving and exploring Islamic intellectual
            heritage.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 4rem;
    background: linear-gradient(
      135deg,
      var(--color-navy-900) 0%,
      var(--color-navy-800) 40%,
      var(--color-navy-700) 100%
    );
    color: var(--color-neutral-50);
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image:
      linear-gradient(
        30deg,
        var(--color-gold-400) 12%,
        transparent 12.5%,
        transparent 87%,
        var(--color-gold-400) 87.5%,
        var(--color-gold-400)
      ),
      linear-gradient(
        150deg,
        var(--color-gold-400) 12%,
        transparent 12.5%,
        transparent 87%,
        var(--color-gold-400) 87.5%,
        var(--color-gold-400)
      ),
      linear-gradient(
        30deg,
        var(--color-gold-400) 12%,
        transparent 12.5%,
        transparent 87%,
        var(--color-gold-400) 87.5%,
        var(--color-gold-400)
      ),
      linear-gradient(
        150deg,
        var(--color-gold-400) 12%,
        transparent 12.5%,
        transparent 87%,
        var(--color-gold-400) 87.5%,
        var(--color-gold-400)
      ),
      linear-gradient(
        60deg,
        var(--color-gold-300) 25%,
        transparent 25.5%,
        transparent 75%,
        var(--color-gold-300) 75%,
        var(--color-gold-300)
      ),
      linear-gradient(
        60deg,
        var(--color-gold-300) 25%,
        transparent 25.5%,
        transparent 75%,
        var(--color-gold-300) 75%,
        var(--color-gold-300)
      );
    background-size: 80px 140px;
    background-position:
      0 0,
      0 0,
      40px 70px,
      40px 70px,
      0 0,
      40px 70px;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-pattern {
      opacity: 0.03;
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    text-align: center;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.7;
    color: var(--color-navy-100);
    max-width: 38rem;
    margin: 0 auto 2.5rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* Buttons */
  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: var(--color-gold-500);
    color: var(--color-navy-950);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      transform 0.15s ease;
  }

  .btn-primary:hover {
    background: var(--color-gold-400);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--color-gold-300);
    outline-offset: 2px;
  }

  .btn-primary:active {
    transform: scale(0.98);
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: transparent;
    color: var(--color-neutral-100);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    border: 1.5px solid var(--color-navy-300);
    border-radius: 0.375rem;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .btn-secondary:hover {
    border-color: var(--color-gold-400);
    color: var(--color-gold-300);
  }

  .btn-secondary:focus-visible {
    outline: 2px solid var(--color-gold-300);
    outline-offset: 2px;
  }

  /* Sections */
  .section {
    padding: 5rem 1.5rem;
  }

  .section-alt {
    background: var(--color-neutral-50);
  }

  .section-container {
    max-width: 64rem;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--color-navy-800);
    text-align: center;
    margin-bottom: 3rem;
  }

  /* Mission */
  .mission-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .mission-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .mission-text {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-neutral-700);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .mission-highlight blockquote {
    border-left: 3px solid var(--color-gold-500);
    padding: 1.5rem 1.5rem 1.5rem 2rem;
    background: var(--color-navy-50);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .mission-highlight blockquote p {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--color-navy-700);
    margin-bottom: 0.75rem;
  }

  .mission-highlight cite {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-neutral-500);
    font-style: normal;
  }

  /* Project Card */
  .project-card {
    display: grid;
    gap: 2rem;
    padding: 2.5rem;
    background: white;
    border-radius: 0.75rem;
    border: 1px solid var(--color-neutral-200);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
  }

  @media (min-width: 768px) {
    .project-card {
      grid-template-columns: auto 1fr;
      align-items: start;
    }
  }

  .project-card-icon {
    color: var(--color-navy-600);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-card-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-navy-800);
    margin-bottom: 1rem;
  }

  .project-card-description {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-neutral-600);
    margin-bottom: 1.25rem;
  }

  .project-card-features {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
    display: grid;
    gap: 0.5rem;
  }

  .project-card-features li {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-neutral-600);
    padding-left: 1.5rem;
    position: relative;
  }

  .project-card-features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-gold-500);
  }

  /* Values Grid */
  .values-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .values-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .value-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .value-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    color: var(--color-navy-600);
  }

  .value-title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-navy-800);
    margin-bottom: 0.75rem;
  }

  .value-description {
    font-family: var(--font-body);
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--color-neutral-600);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .btn-primary,
    .btn-secondary {
      transition: none;
    }
  }
</style>
