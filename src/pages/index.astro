---
import PageLayout from "../layouts/PageLayout.astro";
import SEO from "../components/SEO.astro";
---

<PageLayout
  title="Home"
  description="NoorinALabs builds open tools for Islamic scholarly research — starting with the Isnad Graph, a computational hadith analysis platform."
>
  <SEO slot="head" />

  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="hero-content">
      <h1 id="hero-heading" class="hero-title">
        Illuminating Fourteen Centuries<br />of Islamic Scholarship
      </h1>
      <p class="hero-subtitle">
        The Islamic scholarly tradition represents over fourteen centuries of
        accumulated human knowledge. Noorina Labs builds open tools to make this
        heritage navigable, searchable, and accessible to researchers, students,
        and curious minds worldwide.
      </p>
      <div class="hero-actions">
        <a href="https://isnad-graph.noorinalabs.com" class="btn-primary">
          Explore the Isnad Graph
        </a>
        <a href="/about" class="btn-secondary"> Learn About Us </a>
      </div>
    </div>
  </section>

  <!-- Four Pillars -->
  <section class="section" aria-labelledby="pillars-heading">
    <div class="section-container">
      <h2 id="pillars-heading" class="section-title">Our Pillars</h2>
      <div class="pillars-grid">
        <div class="pillar-card">
          <h3 class="pillar-title">Open Research</h3>
          <p class="pillar-description">
            All code, data pipelines, and research are open source. Transparency
            builds trust and invites collaboration across institutions and
            traditions.
          </p>
        </div>
        <div class="pillar-card">
          <h3 class="pillar-title">Global Reach</h3>
          <p class="pillar-description">
            Built for the global ummah and the wider scholarly community. Our
            tools serve 1.9 billion Muslims and researchers of all backgrounds.
          </p>
        </div>
        <div class="pillar-card">
          <h3 class="pillar-title">Source-Neutral</h3>
          <p class="pillar-description">
            We draw from published scholarly works across traditions. Every data
            point is traceable to its source, ensuring academic rigor.
          </p>
        </div>
        <div class="pillar-card">
          <h3 class="pillar-title">Community-Built</h3>
          <p class="pillar-description">
            Developed in collaboration with scholars, students, and developers
            who share a commitment to preserving Islamic intellectual heritage.
          </p>
        </div>
      </div>
      <div class="principle-banner">
        <blockquote>
          <p>
            "Noorina Labs will never privilege one school of thought over
            another. Our platform illuminates — it does not arbitrate."
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="section section-alt" aria-labelledby="problem-heading">
    <div class="section-container">
      <h2 id="problem-heading" class="section-title">The Problem</h2>
      <p class="section-intro">
        Despite centuries of rigorous scholarship, there is no computational
        tool that connects the dots across traditions. Researchers today still
        cannot easily answer fundamental questions:
      </p>
      <ul class="question-list" role="list">
        <li>
          How do I look up a narrator who appears in both Sunni and Shia
          collections?
        </li>
        <li>
          Which hadith have parallel transmissions across different canonical
          sources?
        </li>
        <li>
          What does the network structure of narration chains reveal about
          knowledge transmission?
        </li>
        <li>
          Where do Sunni and Shia scholarly traditions overlap in their narrator
          evaluations?
        </li>
        <li>
          What patterns emerge in how hadiths are attributed to specific
          Companions?
        </li>
      </ul>
      <div class="stats-row">
        <div class="stat">
          <span class="stat-number">1.9B</span>
          <span class="stat-label">Muslims worldwide</span>
        </div>
        <div class="stat">
          <span class="stat-number">14+</span>
          <span class="stat-label">centuries of scholarship</span>
        </div>
        <div class="stat">
          <span class="stat-number">0</span>
          <span class="stat-label">cross-tradition graph tools</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Isnad Graph Capabilities -->
  <section id="projects" class="section" aria-labelledby="capabilities-heading">
    <div class="section-container">
      <h2 id="capabilities-heading" class="section-title">
        The Isnad Graph Platform
      </h2>
      <p class="section-intro">
        Our first product brings computational analysis to one of the oldest
        systems of knowledge verification in human history.
      </p>
      <div class="capabilities-grid">
        <div class="capability-card">
          <h3 class="capability-title">Cross-Collection Search</h3>
          <p class="capability-description">
            Search narrators and hadiths across multiple canonical collections
            simultaneously, with results linked to their full isnad chains.
          </p>
        </div>
        <div class="capability-card">
          <h3 class="capability-title">Graph Explorer</h3>
          <p class="capability-description">
            Navigate chains of narration as a dynamic, interactive network.
            Zoom, filter, and trace transmission paths between narrators.
          </p>
        </div>
        <div class="capability-card">
          <h3 class="capability-title">Cross-Tradition Comparison</h3>
          <p class="capability-description">
            Compare narrator assessments and transmission pathways across Sunni
            and Shia scholarly traditions in a single unified graph.
          </p>
        </div>
        <div class="capability-card">
          <h3 class="capability-title">Historical Context</h3>
          <p class="capability-description">
            Access biographical data, teacher-student relationships, and
            reliability assessments drawn from classical rijal literature.
          </p>
        </div>
        <div class="capability-card">
          <h3 class="capability-title">Collection-Level Analysis</h3>
          <p class="capability-description">
            Explore patterns within and across hadith collections, including
            shared narrators, common chains, and attribution distributions.
          </p>
        </div>
      </div>
      <div class="section-cta">
        <a href="https://isnad-graph.noorinalabs.com" class="btn-primary">
          Explore the Isnad Graph
        </a>
      </div>
    </div>
  </section>

  <!-- Why Now -->
  <section class="section section-alt" aria-labelledby="why-now-heading">
    <div class="section-container">
      <h2 id="why-now-heading" class="section-title">Why Now</h2>
      <div class="why-now-grid">
        <div class="why-now-card">
          <h3 class="why-now-title">Computational Tools Have Matured</h3>
          <p class="why-now-description">
            Graph databases, network analysis algorithms, and interactive
            visualization frameworks have reached a level of maturity that makes
            this work possible at scale.
          </p>
        </div>
        <div class="why-now-card">
          <h3 class="why-now-title">Open Data Is Available</h3>
          <p class="why-now-description">
            Digitized hadith collections and scholarly databases have reached
            critical mass, making it feasible to build comprehensive,
            cross-referenced datasets.
          </p>
        </div>
        <div class="why-now-card">
          <h3 class="why-now-title">Institutional Appetite Is Growing</h3>
          <p class="why-now-description">
            Universities, research institutions, and Islamic organizations
            worldwide are actively seeking digital tools that respect scholarly
            rigor while embracing modern technology.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partnership & Support -->
  <section class="section" aria-labelledby="partnership-heading">
    <div class="section-container">
      <h2 id="partnership-heading" class="section-title">Partner With Us</h2>
      <p class="section-intro">
        We are building the infrastructure for the next generation of Islamic
        scholarly research. There are several ways to be part of this work.
      </p>
      <div class="partnership-grid">
        <div class="partnership-card">
          <h3 class="partnership-title">Research Partnership</h3>
          <p class="partnership-description">
            Collaborate on data curation, validation, and scholarly review.
            Academic partners help ensure our tools meet the highest standards
            of rigor and accuracy.
          </p>
        </div>
        <div class="partnership-card">
          <h3 class="partnership-title">Institutional License</h3>
          <p class="partnership-description">
            Universities and research organizations can integrate the Isnad
            Graph into their curriculum and research workflows with dedicated
            support and custom data access.
          </p>
        </div>
        <div class="partnership-card">
          <h3 class="partnership-title">Grant & Philanthropic</h3>
          <p class="partnership-description">
            Support the preservation and accessibility of Islamic scholarly
            heritage through grants, endowments, or direct contribution to our
            open-source mission.
          </p>
        </div>
      </div>
      <div class="section-cta">
        <p class="contact-line">
          Interested? Reach out at
          <a href="mailto:info@noorinalabs.com">info@noorinalabs.com</a>
        </p>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 4rem;
    background: linear-gradient(
      135deg,
      var(--color-navy-900) 0%,
      var(--color-navy-800) 40%,
      var(--color-navy-700) 100%
    );
    color: var(--color-neutral-50);
    overflow: hidden;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image:
      linear-gradient(
        30deg,
        var(--color-gold-400) 12%,
        transparent 12.5%,
        transparent 87%,
        var(--color-gold-400) 87.5%,
        var(--color-gold-400)
      ),
      linear-gradient(
        150deg,
        var(--color-gold-400) 12%,
        transparent 12.5%,
        transparent 87%,
        var(--color-gold-400) 87.5%,
        var(--color-gold-400)
      ),
      linear-gradient(
        30deg,
        var(--color-gold-400) 12%,
        transparent 12.5%,
        transparent 87%,
        var(--color-gold-400) 87.5%,
        var(--color-gold-400)
      ),
      linear-gradient(
        150deg,
        var(--color-gold-400) 12%,
        transparent 12.5%,
        transparent 87%,
        var(--color-gold-400) 87.5%,
        var(--color-gold-400)
      ),
      linear-gradient(
        60deg,
        var(--color-gold-300) 25%,
        transparent 25.5%,
        transparent 75%,
        var(--color-gold-300) 75%,
        var(--color-gold-300)
      ),
      linear-gradient(
        60deg,
        var(--color-gold-300) 25%,
        transparent 25.5%,
        transparent 75%,
        var(--color-gold-300) 75%,
        var(--color-gold-300)
      );
    background-size: 80px 140px;
    background-position:
      0 0,
      0 0,
      40px 70px,
      40px 70px,
      0 0,
      40px 70px;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-pattern {
      opacity: 0.03;
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    text-align: center;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.7;
    color: var(--color-navy-100);
    max-width: 38rem;
    margin: 0 auto 2.5rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  /* Buttons */
  .btn-primary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: var(--color-gold-500);
    color: var(--color-navy-950);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      transform 0.15s ease;
  }

  .btn-primary:hover {
    background: var(--color-gold-400);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--color-gold-300);
    outline-offset: 2px;
  }

  .btn-primary:active {
    transform: scale(0.98);
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: transparent;
    color: var(--color-neutral-100);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    border: 1.5px solid var(--color-navy-300);
    border-radius: 0.375rem;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .btn-secondary:hover {
    border-color: var(--color-gold-400);
    color: var(--color-gold-300);
  }

  .btn-secondary:focus-visible {
    outline: 2px solid var(--color-gold-300);
    outline-offset: 2px;
  }

  /* Sections */
  .section {
    padding: 5rem 1.5rem;
  }

  .section-alt {
    background: var(--color-neutral-50);
  }

  .section-container {
    max-width: 64rem;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--color-navy-800);
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .section-intro {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-neutral-600);
    text-align: center;
    max-width: 42rem;
    margin: 0 auto 3rem;
  }

  .section-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* Four Pillars */
  .pillars-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
    margin-top: 2rem;
  }

  @media (min-width: 640px) {
    .pillars-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pillars-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .pillar-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .pillar-title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-navy-800);
    margin-bottom: 0.75rem;
  }

  .pillar-description {
    font-family: var(--font-body);
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--color-neutral-600);
  }

  .principle-banner {
    margin-top: 3rem;
    text-align: center;
  }

  .principle-banner blockquote {
    border-left: 3px solid var(--color-gold-500);
    padding: 1.5rem 2rem;
    background: var(--color-navy-50);
    border-radius: 0 0.5rem 0.5rem 0;
    display: inline-block;
    text-align: left;
    max-width: 42rem;
  }

  .principle-banner blockquote p {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--color-navy-700);
  }

  /* The Problem */
  .question-list {
    list-style: none;
    padding: 0;
    max-width: 42rem;
    margin: 0 auto 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .question-list li {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-neutral-700);
    padding-left: 1.75rem;
    position: relative;
  }

  .question-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-gold-500);
  }

  .stats-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
    margin-top: 2rem;
  }

  .stat {
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-navy-800);
    line-height: 1.2;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-neutral-500);
  }

  /* Capabilities */
  .capabilities-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .capabilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .capabilities-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .capability-card {
    padding: 2rem;
    background: var(--color-neutral-50);
    border-radius: 0.75rem;
    border: 1px solid var(--color-neutral-200);
  }

  .capability-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy-800);
    margin-bottom: 0.75rem;
  }

  .capability-description {
    font-family: var(--font-body);
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--color-neutral-600);
  }

  /* Why Now */
  .why-now-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .why-now-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .why-now-card {
    padding: 2rem;
    background: white;
    border-radius: 0.75rem;
    border: 1px solid var(--color-neutral-200);
  }

  .why-now-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy-800);
    margin-bottom: 0.75rem;
  }

  .why-now-description {
    font-family: var(--font-body);
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--color-neutral-600);
  }

  /* Partnership */
  .partnership-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .partnership-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .partnership-card {
    padding: 2rem;
    background: var(--color-neutral-50);
    border-radius: 0.75rem;
    border: 1px solid var(--color-neutral-200);
  }

  .partnership-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy-800);
    margin-bottom: 0.75rem;
  }

  .partnership-description {
    font-family: var(--font-body);
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--color-neutral-600);
  }

  .contact-line {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--color-neutral-600);
  }

  .contact-line a {
    color: var(--color-navy-700);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .contact-line a:hover {
    color: var(--color-gold-600);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .btn-primary,
    .btn-secondary {
      transition: none;
    }
  }
</style>
